<% layout('/layouts/boilerplate') -%>

<div class="container mt-5">
    <div class="row">
        <div class="col-12 mb-4">
            <h1 class="display-4">Welcome back, <%= currUser.username %>!</h1>
            <p class="text-muted">Manage your dream trips and saved destinations.</p>
        </div>
    </div>

    <!-- Favorites Section -->
    <div class="row mt-4">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <h2><i class="fa-solid fa-heart text-danger"></i> My Favorites</h2>
            <a href="/listings" class="btn btn-outline-primary btn-sm">Explore More</a>
        </div>
        <% if (user.favorites && user.favorites.length > 0) { %>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
                <% for(let listing of user.favorites) { %>
                    <div class="col mb-4">
                        <div class="card listing-card h-100 shadow-sm">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 200px; object-fit: cover;">
                            <div class="card-img-overlay"></div>
                            <div class="card-body p-3">
                                <p class="card-text">
                                    <b><%= listing.title %></b> <br>
                                    &#x20B9; <%= listing.price.toLocaleString("en-IN") %> / night
                                </p>
                                <div class="d-flex justify-content-between">
                                    <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-dark">View Detail</a>
                                    <form action="/planner/favorites/<%= listing._id %>?_method=DELETE" method="POST">
                                        <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="col-12 text-center py-5 bg-light rounded shadow-sm">
                <i class="fa-regular fa-bookmark fa-3x mb-3 text-muted"></i>
                <p>No favorites yet. Start saving destinations you love!</p>
                <a href="/listings" class="btn btn-primary">Find Destinations</a>
            </div>
        <% } %>
    </div>

    <hr class="my-5">

    <!-- Itineraries Section -->
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <h2><i class="fa-solid fa-map-location-dot text-success"></i> My Itineraries</h2>
            <a href="/planner/itinerary/new" class="btn btn-success"><i class="fa-solid fa-plus"></i> Create New Plan</a>
        </div>
        <% if (itineraries && itineraries.length > 0) { %>
            <div class="row">
                <% for(let itinerary of itineraries) { %>
                    <div class="col-md-6 mb-4">
                        <div class="card shadow-sm h-100 border-0">
                            <div class="card-body">
                                <h5 class="card-title d-flex justify-content-between">
                                    <%= itinerary.title %>
                                    <small class="text-muted"><%= itinerary.createdAt.toLocaleDateString() %></small>
                                </h5>
                                <p class="card-text"><%= itinerary.items.length %> destinations planned.</p>
                                <div class="mt-3">
                                    <a href="/planner/itinerary/<%= itinerary._id %>" class="btn btn-outline-primary btn-sm">Edit / View</a>
                                    <form action="/planner/itinerary/<%= itinerary._id %>?_method=DELETE" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-link text-danger">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="col-12 text-center py-5 bg-light rounded shadow-sm">
                <i class="fa-solid fa-route fa-3x mb-3 text-muted"></i>
                <p>No itineraries yet. Plan your next adventure!</p>
                <a href="/planner/itinerary/new" class="btn btn-success">Create Itinerary</a>
            </div>
        <% } %>
    </div>
</div>

<style>
    .listing-card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>
