<% layout('/layouts/boilerplate') -%>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h2 class="mb-4 text-center">Plan Your New Adventure</h2>
            <form action="/planner/itinerary" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="title" class="form-label">Trip Title</label>
                    <input type="text" name="title" id="title" class="form-control"
                        placeholder="e.g. Summer in Himachal" required>
                    <div class="invalid-feedback">Please provide a title for your trip.</div>
                </div>

                <h4>Select Destinations from Your Favorites</h4>
                <div id="itinerary-items" class="mt-3">
                    <!-- Trip Item 1 (Template) -->
                    <div class="card mb-3 itinerary-item border-0 shadow-sm bg-light">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-5 mb-2">
                                    <label class="form-label">Destination</label>
                                    <select name="items[0][listing]" class="form-select" required>
                                        <option value="">Choose a Favorite...</option>
                                        <% for(let favorite of user.favorites) { %>
                                            <option value="<%= favorite._id %>">
                                                <%= favorite.title %> (<%= favorite.location %>)
                                            </option>
                                            <% } %>
                                    </select>
                                </div>
                                <div class="col-md-2 mb-2">
                                    <label class="form-label">Day</label>
                                    <input type="number" name="items[0][day]" class="form-control" value="1" min="1"
                                        required>
                                </div>
                                <div class="col-md-5 mb-2">
                                    <label class="form-label">Notes</label>
                                    <input type="text" name="items[0][notes]" class="form-control"
                                        placeholder="e.g. Hiking day!">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="button" id="add-item-btn" class="btn btn-outline-dark mb-4">
                    <i class="fa-solid fa-plus"></i> Add Another Destination
                </button>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg">Create Itinerary</button>
                    <a href="/planner/dashboard" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        let itemIndex = 1;
        document.getElementById('add-item-btn').addEventListener('click', () => {
            const container = document.getElementById('itinerary-items');
            const newItem = document.createElement('div');
            newItem.className = 'card mb-3 itinerary-item border-0 shadow-sm bg-light';
            newItem.innerHTML = `
            <div class="card-body">
                <div class="row">
                    <div class="col-md-5 mb-2">
                        <label class="form-label">Destination</label>
                        <select name="items[\${itemIndex}][listing]" class="form-select" required>
                            <option value="">Choose a Favorite...</option>
                            <% for(let favorite of user.favorites) { %>
                                <option value="<%= favorite._id %>"><%= favorite.title %> (<%= favorite.location %>)</option>
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-2 mb-2">
                        <label class="form-label">Day</label>
                        <input type="number" name="items[\${itemIndex}][day]" class="form-control" value="1" min="1" required>
                    </div>
                    <div class="col-md-5 mb-2">
                        <label class="form-label">Notes</label>
                        <input type="text" name="items[\${itemIndex}][notes]" class="form-control" placeholder="e.g. Visit Museum">
                    </div>
                </div>
            </div>
        `;
            container.appendChild(newItem);
            itemIndex++;
        });
    </script>