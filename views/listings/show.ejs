<!-- BOOKING FORM -->

<% if(currUser && listing.owner && !currUser._id.equals(listing.owner._id)){ %>

<div class="col-6 offset-3 mt-4 mb-3">

<div class="card shadow-sm border-0"
     style="border-radius:12px;overflow:hidden;">

<div class="card-header text-white fw-bold"
     style="background:linear-gradient(135deg,#2c3e50,#4ca1af);">

<i class="fa-solid fa-calendar-check me-2"></i>
Book this Listing

</div>

<div class="card-body" style="background:#f8f9fa;">

<form action="/listings/<%= listing._id %>/bookings"
      method="POST"
      id="bookingForm"
      novalidate
      class="needs-validation">

<div class="row g-3">

<div class="col-md-6">

<label class="form-label fw-semibold">Check-in Date</label>

<input type="date"
    name="booking[checkIn]"
    id="checkIn"
    class="form-control"
    required
    min="<%= new Date().toISOString().split('T')[0] %>">

</div>

<div class="col-md-6">

<label class="form-label fw-semibold">Check-out Date</label>

<input type="date"
    name="booking[checkOut]"
    id="checkOut"
    class="form-control"
    required
    min="<%= new Date().toISOString().split('T')[0] %>">

</div>

<div class="col-md-6">

<label class="form-label fw-semibold">
Number of Guests
<span class="text-muted">
(max <%= listing.maxGuests || 1 %>)
</span>
</label>

<input type="number"
    name="booking[guests]"
    id="guests"
    class="form-control"
    min="1"
    max="<%= listing.maxGuests || 1 %>"
    value="1"
    required>

</div>

<div class="col-md-6 d-flex align-items-end">

<div id="pricePreview"
     class="w-100 p-3 rounded text-center"
     style="background:#e8f4f8;border:1px dashed #4ca1af;display:none;">

<div class="text-muted small">Estimated Total</div>

<div class="fw-bold fs-5 text-success"
     id="totalPriceDisplay">

₹0

</div>

<div class="text-muted small"
     id="priceBreakdown">

</div>

</div>
</div>
</div>

<div class="mt-4">

<button type="submit"
     class="btn btn-dark w-100 py-2 fw-bold">

<i class="fa-solid fa-bolt me-1"></i>
Confirm Booking

</button>

</div>

</form>
</div>
</div>
</div>

<% } %>

<!-- REVIEWS -->

<div class="col-6 offset-3 mb-3">

<hr>

<% if(currUser){ %>

<h4>Leave a review</h4>

<form action="/listings/<%= listing._id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation">

<label class="form-label">Rating</label>

<fieldset class="starability-slot">

<input type="radio"
    id="no-rate"
    class="input-no-rate"
    name="review[rating]"
    value="1"
    checked>

<input type="radio" name="review[rating]" value="1">
<input type="radio" name="review[rating]" value="2">
<input type="radio" name="review[rating]" value="3">
<input type="radio" name="review[rating]" value="4">
<input type="radio" name="review[rating]" value="5">

</fieldset>

<label class="form-label">Comment</label>

<textarea name="review[comment]"
          class="form-control"
          required>

</textarea>

<button class="btn btn-outline-dark mt-2">Submit</button>

</form>

<% } %>

<% if(listing.reviews.length>0){ %>

<hr>
<p><b>All Reviews</b></p>

<% for(review of listing.reviews){ %>

<div class="card col-md-12 col-lg-5 col-sm-12 ms-3 mb-3">

<div class="card-body">

<h5>@<%= review.author.username %></h5>

<p class="starability-result"
   data-rating="<%= review.rating %>">

stars

</p>

<p><%= review.comment %></p>

</div>

<% if(currUser && currUser._id.equals(review.author._id)){ %>

<form method="POST"
      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

<button class="btn btn-sm btn-dark">Delete</button>

</form>

<% } %>

</div>

<% } %>

<% } %>

</div>

<!-- MAP -->

<div class="col-6 offset-3 mb-3">

<h3>Where you'll be</h3>

<div id="map"></div>

</div>

<script src="/js/map.js"></script>

<script>
const basePrice = listingData.price;
const checkInEl = document.getElementById('checkIn');
const checkOutEl = document.getElementById('checkOut');
const guestsEl = document.getElementById('guests');
const previewEl = document.getElementById('pricePreview');
const totalEl = document.getElementById('totalPriceDisplay');
const breakdownEl = document.getElementById('priceBreakdown');

function updatePreview(){

if(!checkInEl || !checkOutEl || !guestsEl) return;

const checkIn = new Date(checkInEl.value);
const checkOut = new Date(checkOutEl.value);
const guests = parseInt(guestsEl.value) || 0;

if(!checkInEl.value || !checkOutEl.value || checkOut <= checkIn){

previewEl.style.display='none';
return;

}

const nights = Math.ceil((checkOut-checkIn)/(1000*60*60*24));
const total = basePrice * guests * nights;

totalEl.textContent='₹'+total.toLocaleString('en-IN');
breakdownEl.textContent=`₹${basePrice} × ${guests} guest × ${nights} night`;

previewEl.style.display='block';

}

if(checkInEl){

checkInEl.addEventListener('change',updatePreview);
checkOutEl.addEventListener('change',updatePreview);
guestsEl.addEventListener('input',updatePreview);

}
</script>
