<% layout('/layouts/boilerplate') -%>

<div id="listing-data"
     data-listing='<%- JSON.stringify(listing) %>'
     data-map-token="<%= process.env.MAP_TOKEN %>"
     style="display:none;">
</div>

<script>
const mapToken = document.getElementById("listing-data").dataset.mapToken;
const listingData = JSON.parse(document.getElementById("listing-data").dataset.listing);
</script>

<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card listing-card col-6 offset-3 show-card">

```
<!-- IMAGE CAROUSEL -->
<div id="listingCarousel" class="carousel slide" data-bs-ride="carousel">

  <div class="carousel-inner">

    <% let carouselImages =
    listing.images && listing.images.length > 0
    ? listing.images
    : (listing.image ? [listing.image] : []) %>

    <% carouselImages.forEach((img,index)=>{ %>

    <div class="carousel-item <%= index===0 ? 'active' : '' %>">
      <img src="<%= img.url %>" class="d-block w-100 show-img">
    </div>

    <% }) %>

  </div>

  <% if(carouselImages.length>1){ %>

  <button class="carousel-control-prev"
          type="button"
          data-bs-target="#listingCarousel"
          data-bs-slide="prev">

    <span class="carousel-control-prev-icon"></span>

  </button>

  <button class="carousel-control-next"
          type="button"
          data-bs-target="#listingCarousel"
          data-bs-slide="next">

    <span class="carousel-control-next-icon"></span>

  </button>

  <% } %>

</div>

<div class="card-body">

  <p class="card-text">
    Owned By:
    <i><%= listing.owner ? listing.owner.username : "WanderLust" %></i>
  </p>

  <p class="card-text"><%= listing.description %></p>

  <p class="card-text">
    &#x20B9; <%= listing.price.toLocaleString("en-IN") %> / night
  </p>

  <p class="card-text">
    <i class="fa-solid fa-users"></i>
    Max Guests:
    <strong><%= listing.maxGuests || 1 %></strong>
  </p>

  <p class="card-text"><%= listing.location %></p>
  <p class="card-text"><%= listing.country %></p>

  <% if(currUser){ %>

  <hr>

  <% if(currUser.favorites && currUser.favorites.includes(listing._id.toString())){ %>

  <form action="/planner/favorites/<%= listing._id %>?_method=DELETE" method="POST">
    <button class="btn btn-danger btn-sm">
      <i class="fa-solid fa-heart"></i> Remove from Favorites
    </button>
  </form>

  <% } else { %>

  <form action="/planner/favorites/<%= listing._id %>" method="POST">
    <button class="btn btn-outline-danger btn-sm">
      <i class="fa-regular fa-heart"></i> Add to Favorites
    </button>
  </form>

  <% } %>

  <% } %>

</div>
